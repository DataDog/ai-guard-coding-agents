#!/bin/sh
# Generated by `ai-guard install`. Do not edit by hand — edit
# ~/.ai_guard/config.env and restart the service, or `ai-guard uninstall`
# and re-install.
#
# ``exec`` so the proxy replaces the shell as the init system's direct child.
# This matters for socket activation: launchd's ``launch_activate_socket`` and
# systemd's ``LISTEN_PID`` both identify the recipient by the immediate child
# pid of the spawning job — a pipeline or non-exec shell would break the
# handoff and force the proxy onto the EADDRINUSE fallback path.
set -e
if [ -f "${CONFIG_ENV}" ]; then
    set -a
    . "${CONFIG_ENV}"
    set +a
fi
exec "${BINARY}" proxy
